# Copy to /root/.env on the Hetzner box (next to server.js). Real env vars win.

# Port nginx proxies to (prod uses 3001).
PORT=3001

# /session auth gate (PLAN.md "Gate 2"). Leave UNSET until the same secret is
# also set on Vercel (QUIZ_TOKEN_SECRET) and consoles are re-uploaded — setting
# it here alone locks every existing teacher console out of creating rooms.
# Generate with: openssl rand -hex 32
#QUIZ_TOKEN_SECRET=

# CORS allowlist: comma-separated origin(s) of the WEBSITE (not this backend)
# that serve the student pages and teacher consoles. Unset → any origin is
# reflected (v3 behavior). Example:
#LIVE_ALLOWED_ORIGINS=https://mathsabaq.online,https://geo-explainer.vercel.app

# Require the per-session hostSecret on /start, /end and /live so only the
# teacher who opened a room can control or watch it. Leave UNSET until all
# consoles (React redeploy + any re-uploaded HTML) send the secret; the React
# console does automatically once this build is deployed to the site.
#LIVE_HOST_SECRET_ENFORCED=1

# Per-IP request ceiling per minute (default 2000; 0 disables) and max
# concurrent /live SSE streams per IP (default 50). Defaults suit a NAT'd
# classroom; lower them only if you understand your traffic shape.
#LIVE_RATE_LIMIT_PER_MIN=2000
#LIVE_MAX_SSE_PER_IP=50
